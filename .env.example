# PostgreSQL
POSTGRES_USER=sas
POSTGRES_PASSWORD=change_me
POSTGRES_DB=sas
DATABASE_URL=postgresql+psycopg2://sas:change_me@db:5432/sas

# RabbitMQ / Celery
RABBITMQ_DEFAULT_USER=sas
RABBITMQ_DEFAULT_PASS=change_me
RABBITMQ_URL=amqp://sas:change_me@rabbitmq:5672//
CELERY_BROKER_URL=amqp://sas:change_me@rabbitmq:5672//
# CELERY_RESULT_BACKEND=db+postgresql+psycopg2://sas:change_me@db:5432/sas

# Spectrum / runtime
SAS_PROFILE=cbrs_winnforum
SAS_ADMIN_ID=sas_admin_id
FAD_PUBLIC_BASE=https://localhost:9000
SAS_SAS_VERSION=v1.3
HTTP_TIMEOUT_SECONDS=30
MAX_BATCH_SIZE=100

# API listeners
API_HOST=0.0.0.0
RSA_PORT=9000
ECC_PORT=9001

# Directory on the Docker host containing server.cert, server.key, ca.cert,
# optional server-ecc.* and crl/. For a standalone deployment, provision it
# inside this project as ./certs (kept out of Git).
CERTS_HOST_DIR=./certs
CERTS_DIR=/certs

# External federal / marketplace DB basic auth
DB_SYNC_USERNAME=username
DB_SYNC_PASSWORD=change_me

# Connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
